# === Required ===
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/legal_ai
SECRET_KEY=  # Generate with: openssl rand -hex 32
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# === Optional ===
ANTHROPIC_API_KEY=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-lovable-app.lovable.app

# Razorpay Payment Gateway
# Test keys: rzp_test_... | Live keys: rzp_live_...
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=  # Generate: openssl rand -hex 32 — same value goes in Razorpay Dashboard > Webhooks

# Google OAuth
GOOGLE_CLIENT_ID=

# N8N Webhook (for email dispatch)
N8N_WEBHOOK_URL=

# SMTP (for email reminders)
# --- SendGrid (recommended for production) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey                          # literally the word "apikey"
# SMTP_PASSWORD=SG.your-sendgrid-api-key    # your SendGrid API key
# SMTP_FROM_EMAIL=notifications@yourdomain.com  # must be verified in SendGrid

# --- Gmail (for development / low volume) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password             # Gmail App Password (not your real password)
SMTP_FROM_EMAIL=your@gmail.com

# Storage Backend — "local" or "s3"
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=                           # https://storage.googleapis.com for GCS
